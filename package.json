{
  "name": "portfolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "npm run build-only && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "deploy": "npm run build-only && wrangler deploy"
  },
  "dependencies": {
    "amfe-flexible": "^2.2.1",
    "aos": "^2.3.4",
    "imagesloaded": "^5.0.0",
    "lodash-es": "^4.17.23",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/aos": "^3.0.7",
    "@types/imagesloaded": "^4.1.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.11.0",
    "@types/postcss-pxtorem": "^6.1.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "less": "^4.5.1",
    "less-loader": "^12.3.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.71.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
